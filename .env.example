# Environment Variables Template
# Copy this to .env and fill in your actual values
# NEVER commit the .env file to git!

# =============================================================================
# BRONZE TIER - Basic Configuration
# =============================================================================

# Obsidian Vault Path
VAULT_PATH=./Bronze/AI_Employee_Vault

# Claude Code Configuration
CLAUDE_API_KEY=your_claude_api_key_here

# Watcher Configuration
WATCHER_CHECK_INTERVAL=60  # seconds

# Logging
LOG_LEVEL=INFO
LOG_PATH=./Bronze/AI_Employee_Vault/Logs

# =============================================================================
# SILVER TIER - Additional Services
# =============================================================================

# Gmail API
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# WhatsApp (Playwright Session)
WHATSAPP_SESSION_PATH=/secure/path/to/whatsapp-session

# MCP Server Configuration
MCP_EMAIL_PORT=3000
MCP_SOCIAL_PORT=3001

# =============================================================================
# GOLD TIER - Business Integration
# =============================================================================

# Odoo Configuration
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_USERNAME=admin
ODOO_PASSWORD=your_secure_password

# Facebook API
FACEBOOK_ACCESS_TOKEN=your_facebook_token
FACEBOOK_PAGE_ID=your_page_id

# Instagram API
INSTAGRAM_ACCESS_TOKEN=your_instagram_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_account_id

# Twitter API
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# Banking API (if applicable)
BANK_API_KEY=your_bank_api_key
BANK_API_SECRET=your_bank_api_secret

# =============================================================================
# PLATINUM TIER - Cloud Deployment
# =============================================================================

# Cloud VM Configuration
CLOUD_VM_IP=your_vm_ip_address
CLOUD_VM_USER=ubuntu
CLOUD_SSH_KEY_PATH=/path/to/ssh/key

# Vault Sync
GIT_SYNC_REMOTE=git@github.com:yourusername/ai-employee-vault.git
SYNC_INTERVAL=300  # seconds (5 minutes)

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=your_grafana_password

# Health Check
HEALTH_CHECK_INTERVAL=60  # seconds
ALERT_EMAIL=your_email@example.com

# Cloud Odoo
CLOUD_ODOO_URL=https://odoo.yourdomain.com
CLOUD_ODOO_SSL_CERT=/path/to/ssl/cert
CLOUD_ODOO_SSL_KEY=/path/to/ssl/key

# Backup Configuration
BACKUP_PATH=/path/to/backups
BACKUP_RETENTION_DAYS=90

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Encryption
VAULT_ENCRYPTION_KEY=your_encryption_key_here

# Rate Limiting
MAX_API_CALLS_PER_HOUR=100
MAX_EMAILS_PER_DAY=50
MAX_SOCIAL_POSTS_PER_DAY=10

# Approval Thresholds
AUTO_APPROVE_EMAIL_KNOWN_CONTACTS=true
AUTO_APPROVE_PAYMENT_UNDER=50  # dollars
REQUIRE_APPROVAL_NEW_RECIPIENTS=true

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development Mode (prevents real actions)
DEV_MODE=true
DRY_RUN=true

# Debug
DEBUG=false
VERBOSE_LOGGING=false

# Testing
TEST_MODE=false
TEST_DATA_PATH=./test_data
