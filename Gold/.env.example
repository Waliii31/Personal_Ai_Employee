# Odoo Configuration
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password_here

# Facebook Configuration
FACEBOOK_PAGE_ID=your_page_id
