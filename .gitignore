# Project-wide gitignore for Personal AI Employee

# Environment variables and secrets
.env
.env.*
!.env.example
*.key
*.pem
secrets/
credentials/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
venv/
ENV/
env/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm

# Obsidian
.obsidian/
.trash/

# Logs
*.log
logs/
*.log.*

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# WhatsApp sessions
**/whatsapp-session/
*.session
*.session-journal

# Banking and sensitive data
**/bank_credentials/
**/payment_tokens/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Odoo
odoo-data/
odoo-logs/
filestore/

# Docker
docker-compose.override.yml

# Backups
*.backup
*.sql
*.dump

# MCP server builds
mcp-servers/**/dist/
mcp-servers/**/build/

# Test files (keep test scripts, ignore test data)
test_data/
*.test.db

# Sync conflicts
*.sync-conflict-*

# Cloud deployment
terraform.tfstate
terraform.tfstate.backup
.terraform/

# Personal notes (not part of the system)
PERSONAL_NOTES.md
TODO_PRIVATE.md
